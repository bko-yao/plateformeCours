# --- Base de donnees (PostgreSQL) ---
# Dev local : lancer un Postgres (ex. Docker) et pointer DATABASE_URL dessus.
#   docker run --name preceptio-db -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=preceptio -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/preceptio?schema=public"
# Prod / preview : base managee (Neon, Vercel Postgres...).
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Credit d'impot Services a la Personne ---
CREDIT_IMPOT_RATE="0.5"

# --- Paiement Stripe ---
# Sans cle : l'app fonctionne en "mode demo" (paiement simule).
# Avec cle : vrai paiement via Stripe Checkout sur la page /paiement/[id].
# STRIPE_SECRET_KEY="sk_test_..."
# Secret du webhook (Dashboard Stripe -> Developers -> Webhooks ->
# endpoint /api/webhooks/stripe, evenement checkout.session.completed) :
# STRIPE_WEBHOOK_SECRET="whsec_..."

